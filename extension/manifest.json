{
  "manifest_version": 3,
  "name": "MAPIS Threat Shield",
  "description": "Multilayer Adaptive Phishing Intelligence System browser protection.",
  "version": "1.1",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5001/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:5002/*",
    "http://localhost:5002/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "MAPIS Threat Shield"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
